{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Kill Backend",
      "type": "shell",
      "command": "lsof -ti:4343 | xargs kill -9 || true",
      "presentation": { "panel": "shared", "reveal": "silent" }
    },
    {
      "label": "Start Frontend",
      "type": "shell",
      "command": "cd frontend && npm run dev",
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "." },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "ready in"
        }
      },
      "presentation": { "panel": "dedicated", "reveal": "always" }
    },
    {
      "label": "Start All",
      "dependsOn": ["Kill Backend", "Start Frontend"],
      "dependsOrder": "sequence"
    }
  ]
}